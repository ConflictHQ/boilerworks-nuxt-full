{
  "name": "boilerworks-nuxt-full",
  "version": "1.0.0",
  "private": true,
  "description": "Boilerworks Nuxt 3 full-stack template with PostgreSQL, Drizzle ORM, and session auth",
  "scripts": {
    "dev": "nuxt dev --port 3005",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/database/seed.ts"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.9.0",
    "@vueuse/core": "^12.0.0",
    "@vueuse/nuxt": "^12.0.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.0",
    "nuxt": "^3.16.0",
    "pinia": "^2.3.0",
    "postgres": "^3.4.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.0",
    "@nuxt/eslint": "^0.7.0",
    "@nuxt/icon": "^1.0.0",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/color-mode": "^3.5.0",
    "@nuxtjs/tailwindcss": "^6.13.0",
    "@types/bcryptjs": "^2.4.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.0",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.8.9",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
